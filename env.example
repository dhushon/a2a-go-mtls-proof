# Environment: dev, prod
ENVIRONMENT=dev

# OAuth Server Configuration
# Type: mock, okta, generic
OAUTH_SERVER_TYPE=mock

# Okta/Generic OAuth Settings (Required if OAUTH_SERVER_TYPE is not mock)
OAUTH_DOMAIN=your-tenant.okta.com
OAUTH_CLIENT_ID=your-client-id
OAUTH_MTLS_DOMAIN=your-tenant.mtls.okta.com

# Observability Level: 0 (Off), 1 (Basic), 2 (Cost), 3 (Debug)
AGENT_OBSERVABILITY_LEVEL=1
